      main .location-section{ background:#FAFAF8 !important; }
      main .testimonials-section{ background:var(--cream) !important; }
      main .faq-section{ background:#FFFFFF !important; }
      main .blog-section{ background:var(--sand) !important; }

      /* ================= WIREFRAME 1 - SERVICES: clean 3-col vertical cards ============ */
      main .services-grid{ grid-template-columns:repeat(3,1fr) !important; }

      /* ================= WIREFRAME 2 - WHY US: horizontal icon-left cards, 2-col ======== */
      main .why-us-grid{ grid-template-columns:repeat(2,1fr) !important; gap:clamp(1rem,2vw,1.5rem) !important; }
      main .why-us-card{ display:grid !important; grid-template-columns:auto 1fr !important;
        column-gap:1.1rem !important; row-gap:.3rem !important; align-items:start !important;
        text-align:left !important; padding:clamp(1.4rem,2vw,1.8rem) !important; }
      main .why-us-card .why-icon{ grid-row:1 / 3 !important; margin:0 !important; align-self:start; }
      main .why-us-card h3{ margin:0 !important; align-self:center; }

      /* ================= WIREFRAME 3 - PROTECTION: highlighted advisory panel, 2-col list = */
      main #protection .detail-content-wide{ background:#FFFFFF; border:1px solid var(--border-glass);
        border-left:4px solid var(--gd); border-radius:var(--radius-lg);
        padding:clamp(1.75rem,3vw,2.75rem) !important; max-width:1000px; margin-inline:auto;
        box-shadow:0 14px 40px -22px rgba(96,62,34,.3); }
      main #protection .detail-content-wide > ul{ display:grid !important; grid-template-columns:1fr 1fr;
        gap:.4rem 2.25rem; margin-top:1.25rem; }

      /* ================= WIREFRAME 4 - HOW TO CHOOSE: 2x2 numbered cards ================= */
      main #family-selection .selection-grid{ grid-template-columns:repeat(2,1fr) !important; }

      /* ================= WIREFRAME 5 - WHAT TO EXPECT: dark 4-step horizontal flow ======= */
      main #what-to-expect .section-kicker{ color:#E5B87E !important; }
      main #what-to-expect h2{ color:#FFFFFF !important; }
      main #what-to-expect .highlight{ -webkit-text-fill-color:#E5B87E; }
