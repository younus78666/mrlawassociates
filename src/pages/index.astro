      .advocate-signature { font-style:italic; font-weight:600; color:var(--accent-gold-dark); }
      .advocate-content .btn { margin-top:.5rem; }
      @media(max-width:768px){ .advocate-grid{ grid-template-columns:1fr; text-align:center; } .advocate-creds{ display:inline-block; } }
    </style>

    <!-- ============ SECTION WIREFRAMES + BACKGROUNDS (original palette, layout-only) ============ -->
    <style>
      main{ --sand:#F3ECE0; --cream:#F5EEE3; --gold-tint:#FBF6EE; --ink-dark:#2B2118;
            --gd:var(--accent-gold-dark); }

      /* ---- distinct background per section (never same as its neighbour) ---- */
      main .services-section{ background:#FFFFFF !important; }
      main .advocate-section{ background:var(--cream) !important; }
      main .why-us-section{ background:var(--gold-tint) !important; }
